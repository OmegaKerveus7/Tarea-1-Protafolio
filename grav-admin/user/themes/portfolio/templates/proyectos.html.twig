{% extends 'partials/base.html.twig' %}

{% block meta %}
<meta name="description" content="Proyectos universitarios de Gustavo Adolfo Tobías Ramírez">
{% endblock %}

{% block title %}Proyectos | Gustavo Tobías{% endblock %}

{% block content %}
<section class="page-hero">
    <div class="container">
        <p class="page-hero__badge">Portafolio</p>
        <h1 class="page-hero__title">Proyectos Universitarios</h1>
        <p class="page-hero__description">Cuatro proyectos liderados desde la arquitectura hasta la entrega.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="grid">

            <div class="card">
                <img src="{{ url('theme://images/batirover.jpeg') }}" alt="Batirrover" class="card__image">
                <div class="card__content">
                    <h3 class="card__title">Batirrover - Robot con IA</h3>
                    <p class="card__meta">2025 - 2026</p>
                    <div class="card__tags">
                        <span class="card__tag">Python</span>
                        <span class="card__tag">TensorFlow</span>
                        <span class="card__tag">OpenCV</span>
                        <span class="card__tag">Arduino</span>
                    </div>
                    <p class="card__description">Robot móvil con navegación autónoma usando visión computacional y redes neuronales.</p>
                    <a href="https://github.com/ZelderD-12/PF-LFA.git" class="card__link" target="_blank">Ver repositorio →</a>
                </div>
            </div>

            <div class="card">
                <img src="{{ url('theme://images/datacentermaketafuncional.jpeg') }}" alt="Datacenter" class="card__image">
                <div class="card__content">
                    <h3 class="card__title">Datacenter Funcional</h3>
                    <p class="card__meta">2025 - 2026</p>
                    <div class="card__tags">
                        <span class="card__tag">Python</span>
                        <span class="card__tag">Docker</span>
                        <span class="card__tag">Raspberry Pi</span>
                        <span class="card__tag">IoT</span>
                    </div>
                    <p class="card__description">Simulación de datacenter con monitoreo de temperatura y control de servidores.</p>
                    <a href="#" class="card__link">Ver repositorio →</a>
                </div>
            </div>

            <div class="card">
                <img src="{{ url('theme://images/robot_de_busqueda_yebacion.jpeg') }}" alt="Robot Búsqueda" class="card__image">
                <div class="card__content">
                    <h3 class="card__title">Robot de Búsqueda y Rescate</h3>
                    <p class="card__meta">2025 - 2026</p>
                    <div class="card__tags">
                        <span class="card__tag">ROS</span>
                        <span class="card__tag">Python</span>
                        <span class="card__tag">LIDAR</span>
                        <span class="card__tag">C++</span>
                    </div>
                    <p class="card__description">Robot para entornos de desastre con mapeo y detección de personas.</p>
                    <a href="#" class="card__link">Ver repositorio →</a>
                </div>
            </div>

            <div class="card">
                <img src="{{ url('theme://images/desarrollo_rover.jpeg') }}" alt="API Compilador" class="card__image">
                <div class="card__content">
                    <h3 class="card__title">API + Compilador UM++</h3>
                    <p class="card__meta">2025 - 2026</p>
                    <div class="card__tags">
                        <span class="card__tag">Java</span>
                        <span class="card__tag">Python</span>
                        <span class="card__tag">FastAPI</span>
                        <span class="card__tag">ANTLR</span>
                    </div>
                    <p class="card__description">Lenguaje UM++ → compilador Java → API Python → comandos al robot.</p>
                    <a href="https://github.com/ZelderD-12/COMPI-PF-CREDENCIALESROBOT.git" class="card__link" target="_blank">Ver repositorio →</a>
                </div>
            </div>

        </div>
    </div>
</section>
{% endblock %}
