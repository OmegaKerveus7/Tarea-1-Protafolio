<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% block meta %}
    <meta name="description" content="{% if page.header.metadata.description %}{{ page.header.metadata.description }}{% else %}Portafolio profesional de Gustavo Adolfo Tobías Ramírez{% endif %}">
    {% endblock %}
    <title>{% block title %}{{ page.title }}{% if page.title != 'Gustavo Tobías | Portafolio' %} | Gustavo Tobías{% endif %}{% endblock %}</title>
    {% block stylesheets %}
    <link rel="stylesheet" href="{{ url('theme://css/index.css') }}">
    <link rel="stylesheet" href="{{ url('theme://css/proyectos.css') }}">
    <link rel="stylesheet" href="{{ url('theme://css/noticias.css') }}">
    {% endblock %}
</head>
<body>
    <header class="header">
        <nav class="nav container">
            <a href="{{ base_url ~ '/' }}" class="nav__logo">Tarea de Desarrollo Web</a>
            <button class="nav__toggle" id="navToggle">☰</button>
            <ul class="nav__menu" id="navMenu">
                <li><a href="{{ base_url ~ '/' }}" class="nav__link {{ page.route == '/' or page.route == '/home' ? 'nav__link--active' : '' }}">Inicio</a></li>
                <li><a href="{{ base_url }}/proyectos" class="nav__link {{ 'proyectos' in page.route ? 'nav__link--active' : '' }}">Proyectos</a></li>
                <li><a href="{{ base_url }}/noticias" class="nav__link {{ 'noticias' in page.route ? 'nav__link--active' : '' }}">Noticias</a></li>
                <li><a href="{{ base_url }}/servicios" class="nav__link {{ 'servicios' in page.route ? 'nav__link--active' : '' }}">Servicios</a></li>
                <li><a href="{{ base_url ~ '/#contacto' }}" class="nav__link">Contacto</a></li>
            </ul>
        </nav>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="container footer__grid">
            <div>
                <a href="{{ base_url ~ '/' }}" class="footer__logo">Tarea de Desarrollo Web</a>
                <p class="footer__tagline">Desarrollador Fullstack · Programador Junior · PM</p>
                <p class="footer__copyright"> <span id="year"></span> Gustavo Adolfo Tobias Ramirez.</p>
            </div>
            <div>
                <h4 class="footer__nav-title">Navegacion</h4>
                <ul class="footer__nav-list">
                    <li><a href="{{ base_url ~ '/' }}" class="footer__nav-link">Inicio</a></li>
                    <li><a href="{{ base_url }}/proyectos" class="footer__nav-link">Proyectos</a></li>
                    <li><a href="{{ base_url }}/noticias" class="footer__nav-link">Noticias</a></li>
                    <li><a href="{{ base_url ~ '/#contacto' }}" class="footer__nav-link">Contacto</a></li>
                </ul>
            </div>
            <div>
                <h4 class="footer__nav-title">Conectar</h4>
                <ul class="footer__social-list">
                    <li><a href="mailto:tobiasgusito@gmail.com" class="footer__social-link">Email</a></li>
                    <li><a href="https://github.com/OmegaKerveus7" class="footer__social-link" target="_blank">GitHub</a></li>
                    <li><a href="https://github.com/ZelderD-12" class="footer__social-link" target="_blank">GitHub</a></li>
                </ul>
            </div>
        </div>
    </footer>

    {% block javascripts %}
    <script src="{{ url('theme://js/index.js') }}"></script>
    <script src="{{ url('theme://js/proyectos.js') }}"></script>
    <script src="{{ url('theme://js/noticias.js') }}"></script>
    {% endblock %}
</body>
</html>
