{% extends 'partials/base.html.twig' %}

{% block meta %}
<meta name="description" content="Noticias y artículos técnicos de Gustavo Adolfo Tobías Ramírez">
{% endblock %}

{% block title %}Noticias | Gustavo Tobías{% endblock %}

{% block content %}
<section class="page-hero">
    <div class="container">
        <p class="page-hero__badge">Blog Técnico</p>
        <h1 class="page-hero__title">Noticias & Artículos</h1>
        <p class="page-hero__description">Documentación de proyectos, herramientas y aprendizajes.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="grid">

            <div class="card">
                <div class="card__content">
                    <p class="card__meta">15 de junio de 2026 · Lenguajes</p>
                    <h3 class="card__title">UM++: Mi primer lenguaje de programación creado</h3>
                    <div class="card__tags">
                        <span class="card__tag">Compiladores</span>
                        <span class="card__tag">Java</span>
                        <span class="card__tag">Python</span>
                        <span class="card__tag">Web PHP</span>
                    </div>
                    <p class="card__description">Cómo diseñé UM++, un lenguaje con tipado estático, para comprender una secuencia de baile paera que un robot lo replique milimetyricamente los pasos.</p>
                </div>
            </div>

            <div class="card">
                <div class="card__content">
                    <p class="card__meta">20 de mayo de 2026 · Robótica</p>
                    <h3 class="card__title">Robot de búsqueda: Robot de navegacion autonoma y manual</h3>
                    <div class="card__tags">
                        <span class="card__tag">Python</span>
                        <span class="card__tag">Arduino</span>
                        <span class="card__tag">Bluetooth</span>
                    </div>
                    <p class="card__description">Implemntacion de los fundamentos de la elecytronica digital y las capacidades de comunicación.</p>
                </div>
            </div>

            <div class="card">
                <div class="card__content">
                    <p class="card__meta">10 de abril de 2026 · IoT</p>
                    <h3 class="card__title">Construyendo un Datacenter IoT con Raspberry Pi</h3>
                    <div class="card__tags">
                        <span class="card__tag">IoT</span>
                        <span class="card__tag">Esp32 Pi</span>
                        <span class="card__tag">Bun</span>
                    </div>
                    <p class="card__description">Sistema de monitoreo de temperatura y control de servidores usando sensores y Esp32 Pi.</p>
                </div>
            </div>

        </div>
    </div>
</section>
{% endblock %}
